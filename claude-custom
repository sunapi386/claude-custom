#!/usr/bin/env bash
# claude-custom — launch `claude` against a custom Anthropic-compatible endpoint.
# Interactively pick a saved profile or create a new one, then exec claude.
#
# Profiles live in $XDG_CONFIG_HOME/claude-custom/profiles/<name>.env
# Each profile is a shell-sourceable file with:
#   BASE_URL=...
#   AUTH_TOKEN=...
#   MODELS=model-a,model-b,...        # comma-separated list of models
#   DEFAULT_MODEL=model-a              # one of the entries in MODELS
#   SMALL_FAST_MODEL=...               # optional, defaults to DEFAULT_MODEL
#
# Legacy single-model profiles using MODEL=... are still supported.

set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-custom"
PROFILE_DIR="$CONFIG_DIR/profiles"
mkdir -p "$PROFILE_DIR"
chmod 700 "$CONFIG_DIR" "$PROFILE_DIR"

die()  { printf 'error: %s\n' "$*" >&2; exit 1; }
info() { printf '\033[36m%s\033[0m\n' "$*"; }
ok()   { printf '\033[32m%s\033[0m\n' "$*"; }

prompt() {
  local var="$1" msg="$2" default="${3:-}" secret="${4:-}" val
  if [[ -n "$default" ]]; then msg="$msg [$default]"; fi
  if [[ "$secret" == "secret" ]]; then
    read -r -s -p "$msg: " val; echo
  else
    read -r -p "$msg: " val
  fi
  [[ -z "$val" && -n "$default" ]] && val="$default"
  printf -v "$var" '%s' "$val"
}

list_profiles() {
  find "$PROFILE_DIR" -maxdepth 1 -type f -name '*.env' -printf '%f\n' 2>/dev/null \
    | sed 's/\.env$//' | sort
}

split_models() {
  # echoes one model per line from a comma-separated list, trimming whitespace
  local IFS=','
  local m
  for m in $1; do
    m="${m#"${m%%[![:space:]]*}"}"; m="${m%"${m##*[![:space:]]}"}"
    [[ -n "$m" ]] && printf '%s\n' "$m"
  done
}

save_profile() {
  local name="$1" base="$2" token="$3" models="$4" default_model="$5" small="$6"
  local file="$PROFILE_DIR/$name.env"
  umask 077
  cat > "$file" <<EOF
BASE_URL=$base
AUTH_TOKEN=$token
MODELS=$models
DEFAULT_MODEL=$default_model
SMALL_FAST_MODEL=$small
EOF
  chmod 600 "$file"
  ok "saved profile → $file"
}

load_profile() {
  local name="$1" file="$PROFILE_DIR/$1.env"
  [[ -f "$file" ]] || die "no such profile: $name"
  unset BASE_URL AUTH_TOKEN MODELS DEFAULT_MODEL MODEL SMALL_FAST_MODEL
  # shellcheck disable=SC1090
  set -a; . "$file"; set +a
  # backwards compat: legacy MODEL= profiles
  if [[ -z "${MODELS:-}" && -n "${MODEL:-}" ]]; then
    MODELS="$MODEL"
    DEFAULT_MODEL="$MODEL"
  fi
  : "${DEFAULT_MODEL:=${MODELS%%,*}}"
  : "${SMALL_FAST_MODEL:=$DEFAULT_MODEL}"
}

# Resolve which model to launch with given an already-loaded profile.
# Argument: optional explicit model (e.g. from CLI). If empty and profile
# has multiple models, prompts. If only one model, uses it silently.
resolve_model() {
  local explicit="${1:-}"
  local models=()
  while IFS= read -r m; do models+=("$m"); done < <(split_models "$MODELS")

  (( ${#models[@]} >= 1 )) || die "profile has no models"

  if [[ -n "$explicit" ]]; then
    local found=""
    for m in "${models[@]}"; do [[ "$m" == "$explicit" ]] && found="$m"; done
    if [[ -z "$found" ]]; then
      info "note: '$explicit' not in profile model list, using it anyway"
      found="$explicit"
    fi
    SELECTED_MODEL="$found"
    return
  fi

  if (( ${#models[@]} == 1 )); then
    SELECTED_MODEL="${models[0]}"
    return
  fi

  echo
  info "pick a model"
  local i=1
  for m in "${models[@]}"; do
    local marker=" "
    [[ "$m" == "$DEFAULT_MODEL" ]] && marker="*"
    printf "  %2d)%s %s\n" "$i" "$marker" "$m"
    ((i++))
  done
  echo
  local choice
  read -r -p "choice [default: $DEFAULT_MODEL]: " choice
  if [[ -z "$choice" ]]; then
    SELECTED_MODEL="$DEFAULT_MODEL"
  elif [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#models[@]} )); then
    SELECTED_MODEL="${models[$((choice-1))]}"
  else
    die "invalid choice"
  fi
}

create_profile_interactive() {
  local name base token models default_model small
  prompt name  "profile name (e.g. zai)"
  [[ -z "$name" ]] && die "name required"
  [[ -f "$PROFILE_DIR/$name.env" ]] && {
    read -r -p "profile '$name' exists. overwrite? [y/N] " yn
    [[ "$yn" == [yY]* ]] || die "aborted"
  }
  prompt base   "endpoint / ANTHROPIC_BASE_URL" "https://api.z.ai/api/anthropic"
  prompt token  "api key / ANTHROPIC_AUTH_TOKEN" "" secret
  [[ -z "$token" ]] && die "token required"
  prompt models "models (comma-separated)" "glm-4.6"
  local first; first=$(split_models "$models" | head -1)
  prompt default_model "default model" "$first"
  prompt small  "small/fast model" "$default_model"
  save_profile "$name" "$base" "$token" "$models" "$default_model" "$small"
  load_profile "$name"
}

pick_profile_interactive() {
  local profiles=()
  while IFS= read -r line; do profiles+=("$line"); done < <(list_profiles)

  echo
  info "claude-custom — pick a profile"
  local i=1
  for p in "${profiles[@]}"; do
    local f="$PROFILE_DIR/$p.env"
    local ms; ms=$(sed -n 's/^MODELS=//p;s/^MODEL=//p' "$f" 2>/dev/null | head -1)
    local b;  b=$(sed -n 's/^BASE_URL=//p' "$f" 2>/dev/null)
    printf "  %2d) %-20s  [%s]  %s\n" "$i" "$p" "$ms" "$b"
    ((i++))
  done
  printf "  %2d) [new profile]\n" "$i"
  printf "  %2d) [delete profile]\n" "$((i+1))"
  echo
  local choice
  read -r -p "choice: " choice
  [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid choice"

  if (( choice == i )); then
    create_profile_interactive
  elif (( choice == i+1 )); then
    read -r -p "name to delete: " dname
    rm -f -- "$PROFILE_DIR/$dname.env" && ok "deleted $dname"
    exit 0
  elif (( choice >= 1 && choice < i )); then
    load_profile "${profiles[$((choice-1))]}"
  else
    die "invalid choice"
  fi
}

usage() {
  cat <<'EOF'
usage:
  claude-custom                                # interactive: pick profile + model, launch
  claude-custom <profile> [args...]            # launch with named profile
  claude-custom <profile> --model <m> [args]   # launch with explicit model
  claude-custom --list                         # list profiles
  claude-custom --new                          # create a new profile (no launch)
  claude-custom --edit <name>                  # open profile in $EDITOR
  claude-custom --add-model <name> <model>     # append model to profile's list
  claude-custom --rm-model <name> <model>      # remove model from profile's list
  claude-custom --delete <name>                # delete a profile
  claude-custom --show <name>                  # print a profile (token masked)
  claude-custom --help

profile model list: comma-separated, picker shown at launch when >1 model.
EOF
}

main() {
  local explicit_model=""
  case "${1:-}" in
    --help|-h) usage; exit 0 ;;
    --list)
      list_profiles | sed 's/^/  /'; exit 0 ;;
    --new)
      create_profile_interactive; exit 0 ;;
    --delete)
      [[ -n "${2:-}" ]] || die "name required"
      rm -f -- "$PROFILE_DIR/$2.env" && ok "deleted $2"; exit 0 ;;
    --edit)
      [[ -n "${2:-}" ]] || die "name required"
      local f="$PROFILE_DIR/$2.env"
      [[ -f "$f" ]] || die "no such profile: $2"
      "${EDITOR:-vi}" "$f"; exit 0 ;;
    --add-model)
      [[ -n "${2:-}" && -n "${3:-}" ]] || die "usage: --add-model <name> <model>"
      load_profile "$2"
      local cur="$MODELS" new="$3"
      case ",$cur," in
        *",$new,"*) info "model '$new' already in profile '$2'"; exit 0 ;;
      esac
      cur="${cur:+$cur,}$new"
      save_profile "$2" "$BASE_URL" "$AUTH_TOKEN" "$cur" "$DEFAULT_MODEL" "$SMALL_FAST_MODEL"
      exit 0 ;;
    --rm-model)
      [[ -n "${2:-}" && -n "${3:-}" ]] || die "usage: --rm-model <name> <model>"
      load_profile "$2"
      local rm_target="$3"
      local kept=""
      while IFS= read -r m; do
        [[ "$m" == "$rm_target" ]] && continue
        kept="${kept:+$kept,}$m"
      done < <(split_models "$MODELS")
      [[ -z "$kept" ]] && die "refusing to remove the only model"
      local new_default="$DEFAULT_MODEL"
      [[ "$DEFAULT_MODEL" == "$rm_target" ]] && new_default="${kept%%,*}"
      local new_small="$SMALL_FAST_MODEL"
      [[ "$SMALL_FAST_MODEL" == "$rm_target" ]] && new_small="$new_default"
      save_profile "$2" "$BASE_URL" "$AUTH_TOKEN" "$kept" "$new_default" "$new_small"
      exit 0 ;;
    --show)
      [[ -n "${2:-}" ]] || die "name required"
      local f="$PROFILE_DIR/$2.env"
      [[ -f "$f" ]] || die "no such profile"
      sed -E 's/^(AUTH_TOKEN)=.*/\1=***masked***/' "$f"; exit 0 ;;
    "")
      if [[ -z "$(list_profiles)" ]]; then
        info "no profiles yet — let's create one"
        create_profile_interactive
      else
        pick_profile_interactive
      fi
      ;;
    -*) die "unknown flag: $1" ;;
    *)
      load_profile "$1"; shift
      # parse optional --model <m> after profile name
      if [[ "${1:-}" == "--model" ]]; then
        [[ -n "${2:-}" ]] || die "--model requires a value"
        explicit_model="$2"; shift 2
      fi
      ;;
  esac

  resolve_model "$explicit_model"

  # Real Claude Code complains if both AUTH_TOKEN and API_KEY are set.
  # AUTH_TOKEN is the right choice for custom Anthropic-compatible endpoints.
  unset ANTHROPIC_API_KEY
  export ANTHROPIC_BASE_URL="$BASE_URL"
  export ANTHROPIC_AUTH_TOKEN="$AUTH_TOKEN"
  export ANTHROPIC_MODEL="$SELECTED_MODEL"
  export ANTHROPIC_SMALL_FAST_MODEL="$SMALL_FAST_MODEL"

  ok "→ $ANTHROPIC_BASE_URL  model=$ANTHROPIC_MODEL"
  command -v claude >/dev/null || die "claude CLI not found on PATH"
  exec claude "$@"
}

main "$@"
